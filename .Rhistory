summary(pca_data)$importance["Proportion of Variance",] * 100
StudyDesign2 <- data.frame(StudyDesign, row.names = 1)
plot_pca <-
as_tibble(pca_data$x) %>%
bind_cols(StudyDesign2)
ggplot(plot_pca, aes(x=PC1, y=PC2,color=Condition,label = rownames(plot_pca))) + geom_point() +
xlab(label = paste("PC1", percent_variance_data[1])) +
ylab(label = paste("PC2", percent_variance_data[2])) +
labs(title = "2D PCA plot for the normalized matrix") +
geom_text_repel( max.overlaps = 30)+theme_bw()

library(data.table)
library(tidyverse)
library(viridis)
DIRin="/Users/arthliams/Documents/Thesis/Modern_Reho_Results/ROH/tests/non_empty_indv/"
DIRout="/Users/arthliams/Documents/Thesis/Modern_Reho_Results/ROH/tests/outdir/"
system(paste0("mkdir -p ",DIRout))
PREFIX="hom.indiv"
FILES=list.files(path = DIRin,pattern = PREFIX)
FILE=FILES[10]
TABLE=data.table()
for(FILE in FILES){
PARAMS=unlist(strsplit(FILE,"\\."))
prune=grep("prune[0-9]",PARAMS,value = T)
Het=grep("Het[0-9]",PARAMS,value = T)
if(length(Het)==0){next}
miss=grep("miss[0-9]",PARAMS,value = T)
win=grep("win[0-9]",PARAMS,value = T)
roh=grep("roh[0-9]",PARAMS,value = T)
thresh=paste(PARAMS[grep("thresh[0-9]",PARAMS)],PARAMS[grep("thresh[0-9]",PARAMS)+1],sep=".")
den=grep("den[0-9]",PARAMS,value = T)
gap=grep("gap[0-9]",PARAMS,value = T)
X=fread(paste0(DIRin,FILE))
X$prune=prune
X$Het=Het
X$miss=miss
X$win=win
X$roh=roh
X$thresh=thresh
X$den=den
X$gap=gap
TABLE=rbind(TABLE,X)
}
hist(TABLE$KB*1e3)
summary(TABLE$KB/1e3)
#het: --homozyg-window-het homozygous in a window
#miss: --homozyg-window-missing missed pos in a window
#win: --homozyg-window-snp scanning window contains X SNPs
#rho: --homozyg-snp runs of homozygosity containing at least X SNPs
unique(TABLE$Het)
TABLE$run=paste(TABLE$prune,TABLE$Het,TABLE$miss,TABLE$win,TABLE$roh,TABLE$thresh,TABLE$den,TABLE$gap)
unique(TABLE$run)
TABLE_summary=TABLE%>%group_by(prune,Het,miss,win,roh,thresh,den,gap)%>%summarise(NSEG=sum(NSEG),KB=sum(KB),KBAVG=mean(KBAVG))%>%data.table()
unique(TABLE_summary$Het)
ggplot(TABLE_summary,aes(Het,KB,col=gap, shape=win)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=miss)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=miss,shape=win)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,KB,col=miss,shape=win)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,KBAVG,col=miss,shape=win)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=miss)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=miss)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=win)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=roh)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=gap)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,KB,col=gap, shape=win)) + geom_jitter(width = 0.2)
ggplot(TABLE_summary,aes(Het,NSEG,col=miss,shape=win)) + geom_jitter(width = 0.2)
